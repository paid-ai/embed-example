# Paid Embed SDK — Test Host Configuration
#
# Copy this file to .env.local and fill in the values from your Paid dashboard.
#
#   cp .env.example .env.local
#
# Then start the server with: npm start

# Where to reach the Paid API and app.
PAID_API_BASE=https://api.agentpaid.io
PAID_APP_BASE=https://app.paid.ai

# A Paid API key — create one in Settings > API keys. This key is used server-side
# to proxy requests (list VRs, publish/unpublish). It never reaches the browser.
PAID_API_KEY=

# JWT signing secret — go to Settings > Embed auth and generate a key.
# Copy the secret from the one-time-reveal modal. Used to sign JWTs server-side.
PAID_SHARE_AUTH_SECRET=

# Server port. Default is 3943.
PORT=3943
